@{
    ViewData["Title"] = "ProjectTimesheet";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/assets/css/timesheet/weeklysheet.css" rel="stylesheet" asp-append-version="true" />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    /* ══════════════════════════════════════
       TAB CHROME
    ══════════════════════════════════════ */
    .ts-tab-strip {
        display: flex;
        gap: 0;
        border-bottom: 2px solid #d0dce8;
        margin-bottom: 0;
    }

    .ts-tab-btn {
        padding: 10px 28px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'IBM Plex Sans', sans-serif;
        border: none;
        border-bottom: 3px solid transparent;
        background: transparent;
        color: #7a94aa;
        cursor: pointer;
        letter-spacing: .3px;
        transition: color .18s, border-color .18s;
        margin-bottom: -2px;
    }

        .ts-tab-btn.active {
            color: #1a3a5c;
            border-bottom-color: #1a3a5c;
        }

        .ts-tab-btn:hover:not(.active) {
            color: #2e5f8a;
        }

    .ts-tab-pane {
        display: none;
    }

        .ts-tab-pane.active {
            display: block;
        }

    /* ══════════════════════════════════════
       SHARED COMPONENTS (week-nav, status-bar, etc.)
       — same as original, scoped to .ts-tab-pane
    ══════════════════════════════════════ */
    .week-nav {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0 14px;
        flex-wrap: wrap;
    }

        .week-nav label {
            font-size: 11px;
            font-weight: 600;
            color: #4a6080;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

    .nav-btn {
        background: #1a3a5c;
        color: #fff;
        border: none;
        border-radius: 4px;
        width: 28px;
        height: 28px;
        font-size: 16px;
        cursor: pointer;
        line-height: 1;
    }

        .nav-btn:hover {
            background: #2e5f8a;
        }

    .week-label {
        font-size: 14px;
        font-weight: 600;
        color: #1a3a5c;
        font-family: 'IBM Plex Mono', monospace;
    }

    .week-sub {
        font-size: 11px;
        color: #7a94aa;
    }

    .year-select {
        padding: 4px 8px;
        border: 1px solid #c8d8e8;
        border-radius: 4px;
        font-size: 13px;
        background: #fff;
        color: #1a3a5c;
    }

    .refresh-btn {
        background: #e8f0f8;
        border: 1px solid #b8cfe0;
        border-radius: 4px;
        padding: 5px 12px;
        font-size: 12px;
        color: #2e5f8a;
        cursor: pointer;
    }

        .refresh-btn:hover {
            background: #d0e4f2;
        }

    .spin {
        display: inline-block;
    }

    .status-bar {
        display: flex;
        align-items: center;
        gap: 16px;
        background: #f0f6fc;
        border: 1px solid #d0e4f0;
        border-radius: 6px;
        padding: 8px 16px;
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .emp-info {
        font-size: 12px;
        color: #4a6080;
    }

    .status-badge {
        margin-left: auto;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 12px;
        background: #d0e8ff;
        color: #1a3a5c;
        letter-spacing: .3px;
    }

    .view-history {
        font-size: 12px;
        color: #2e5f8a;
        text-decoration: underline;
        cursor: pointer;
        margin-left: 8px;
    }

    .emp-row {
        background: #1a3a5c;
        color: #fff;
        border-radius: 6px 6px 0 0;
        padding: 8px 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .emp-field {
        font-size: 11px;
        color: #8ab0cc;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .emp-val {
        font-size: 13px;
        font-weight: 600;
        color: #fff;
    }

    .legend {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding: 8px 0 10px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        color: #4a6080;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

        .legend-dot.present {
            background: #4caf8a;
        }

        .legend-dot.absent {
            background: #f28b5e;
        }

        .legend-dot.holiday {
            background: #7b8fc0;
        }

        .legend-dot.weekend {
            background: #c0c8d8;
        }

        .legend-dot.today {
            background: #f5c842;
        }

    .table-wrap {
        overflow-x: auto;
        border-radius: 0 0 8px 8px;
        border: 1px solid #d0dce8;
    }

    #emp-timesheetTable, #mgr-timesheetTable {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
        background: #fff;
    }

        #emp-timesheetTable th, #mgr-timesheetTable th {
            background: #1a3a5c;
            color: #fff;
            padding: 8px 10px;
            text-align: center;
            font-weight: 500;
            white-space: nowrap;
        }

        #emp-timesheetTable td, #mgr-timesheetTable td {
            padding: 6px 8px;
            border: 1px solid #e0eaf2;
            vertical-align: middle;
            text-align: center;
        }

    .day-cell.present {
        background: #f0fff8;
    }

    .day-cell.absent {
        background: #fff3ee;
    }

    .day-cell.holiday {
        background: #f0f0fc;
    }

    .day-cell.weekend {
        background: #f4f6f8;
    }

    .day-cell.today {
        background: #fffce0;
        border-left: 2px solid #f5c842;
    }

    .date-th.present {
        background: #174d6a;
    }

    .date-th.absent {
        background: #174d6a;
    }

    .date-th.holiday {
        background: #2a2e5c;
    }

    .date-th.weekend {
        background: #263248;
    }

    .date-th.today {
        background: #5a4a00;
    }

    .time-input {
        width: 62px;
        text-align: center;
        border: 1px solid #c8d8e8;
        border-radius: 4px;
        padding: 3px 4px;
        font-size: 12px;
        font-family: 'IBM Plex Mono', monospace;
        background: #f8fcff;
    }

        .time-input:disabled {
            background: #f0f0f4;
            color: #aaa;
            cursor: not-allowed;
        }

        .time-input:focus {
            outline: 2px solid #2e5f8a;
            border-color: #2e5f8a;
        }

    .day-tag {
        display: block;
        font-size: 9px;
        color: #7a94aa;
        text-transform: uppercase;
        letter-spacing: .3px;
        margin-top: 2px;
    }

    .proj-cell {
        text-align: left !important;
        min-width: 220px;
    }

    .proj-select {
        display: block;
        width: 100%;
        margin-bottom: 3px;
        border: 1px solid #c8d8e8;
        border-radius: 3px;
        padding: 3px 6px;
        font-size: 11px;
        color: #1a3a5c;
        background: #f8fcff;
    }

        .proj-select:last-child {
            margin-bottom: 0;
        }

    .remarks-cell {
        min-width: 130px;
        text-align: left !important;
    }

        .remarks-cell textarea {
            width: 100%;
            min-height: 60px;
            border: 1px solid #c8d8e8;
            border-radius: 4px;
            padding: 4px 6px;
            font-size: 11px;
            resize: vertical;
            font-family: 'IBM Plex Sans', sans-serif;
        }

    .action-cell-header, .action-cell {
        width: 60px;
        min-width: 60px;
    }

    .action-icons {
        display: flex;
        gap: 4px;
        justify-content: center;
    }

    .icon-btn {
        background: none;
        border: 1px solid #c8d8e8;
        border-radius: 4px;
        padding: 3px 6px;
        cursor: pointer;
        font-size: 13px;
    }

    .ref-btn:hover {
        background: #e8f4ff;
        border-color: #2e5f8a;
    }

    .del-btn:hover {
        background: #fff0ee;
        border-color: #e05a3a;
    }

    .total-row td {
        background: #e8f0f8 !important;
        font-weight: 700;
    }

    .total-hours {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 13px;
        color: #1a3a5c;
        font-weight: 700;
    }

    .actions-bar {
        display: flex;
        gap: 8px;
        padding: 12px;
        background: #f8fafc;
        border-top: 1px solid #e0eaf2;
    }

    .btn {
        padding: 7px 18px;
        border: none;
        border-radius: 5px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-add {
        background: #e8f4ff;
        color: #1a3a5c;
        border: 1px solid #b8d8f0;
    }

    .btn-upload {
        background: #e8fff4;
        color: #1a5c3a;
        border: 1px solid #b8f0d4;
    }

    .btn-save {
        background: #2e5f8a;
        color: #fff;
    }

    .btn-submit {
        background: #1a3a5c;
        color: #fff;
    }

    .btn:hover {
        opacity: .88;
    }

    .summary-bar {
        display: flex;
        gap: 16px;
        padding: 10px 14px;
        flex-wrap: wrap;
        background: #f0f6fc;
        border-top: 1px solid #d8e8f4;
        border-radius: 0 0 8px 8px;
    }

    .s-item {
        font-size: 12px;
        color: #4a6080;
    }

        .s-item span {
            font-weight: 700;
            color: #1a3a5c;
            margin-left: 4px;
            font-family: 'IBM Plex Mono', monospace;
        }

    .ts-toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background: #1a3a5c;
        color: #fff;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 13px;
        z-index: 9999;
        opacity: 0;
        transform: translateY(10px);
        transition: opacity .25s, transform .25s;
        pointer-events: none;
    }

        .ts-toast.show {
            opacity: 1;
            transform: translateY(0);
        }

    /* ══════════════════════════════════════
       MANAGER TAB SPECIFICS
    ══════════════════════════════════════ */
    .mgr-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        padding: 12px 0 14px;
    }

        .mgr-toolbar label {
            font-size: 11px;
            font-weight: 600;
            color: #4a6080;
            text-transform: uppercase;
            letter-spacing: .4px;
        }

    .mgr-select {
        padding: 5px 10px;
        border: 1px solid #c8d8e8;
        border-radius: 4px;
        font-size: 13px;
        background: #fff;
        color: #1a3a5c;
        min-width: 200px;
    }

    .mgr-filter-btns {
        display: flex;
        gap: 6px;
        margin-left: auto;
    }

    .filter-btn {
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid #c8d8e8;
        background: #f0f6fc;
        color: #4a6080;
        transition: all .15s;
    }

        .filter-btn.active {
            background: #1a3a5c;
            color: #fff;
            border-color: #1a3a5c;
        }

        .filter-btn:hover:not(.active) {
            background: #e0ecf8;
        }

    .emp-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
        margin-bottom: 18px;
    }

    .emp-card {
        border: 2px solid #d0dce8;
        border-radius: 8px;
        padding: 14px 16px;
        background: #fff;
        cursor: pointer;
        transition: border-color .15s, box-shadow .15s;
    }

        .emp-card:hover {
            border-color: #2e5f8a;
            box-shadow: 0 2px 10px rgba(30,80,130,.1);
        }

        .emp-card.selected {
            border-color: #1a3a5c;
            background: #f0f6fc;
        }

    .emp-card-name {
        font-size: 13px;
        font-weight: 700;
        color: #1a3a5c;
    }

    .emp-card-code {
        font-size: 11px;
        color: #7a94aa;
        font-family: 'IBM Plex Mono', monospace;
    }

    .emp-card-status {
        margin-top: 8px;
    }

    .status-pill {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 12px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .3px;
        text-transform: uppercase;
    }

        .status-pill.DRAFT {
            background: #e8e8f0;
            color: #4a4a6a;
        }

        .status-pill.PENDING {
            background: #fff3d0;
            color: #7a5a00;
        }

        .status-pill.APPROVED {
            background: #d4f5e2;
            color: #1a5c3a;
        }

        .status-pill.REJECTED {
            background: #ffe8e4;
            color: #8a1a1a;
        }

    .mgr-detail-panel {
        border: 1px solid #d0dce8;
        border-radius: 8px;
        overflow: hidden;
    }

    .mgr-detail-header {
        background: #1a3a5c;
        color: #fff;
        padding: 10px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

        .mgr-detail-header .emp-name {
            font-size: 14px;
            font-weight: 700;
        }

        .mgr-detail-header .week-lbl {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 12px;
            color: #8ab0cc;
            margin-left: auto;
        }

    .approve-bar {
        display: flex;
        gap: 10px;
        align-items: center;
        padding: 12px 14px;
        background: #f8fafc;
        border-top: 1px solid #e0eaf2;
    }

        .approve-bar textarea {
            flex: 1;
            border: 1px solid #c8d8e8;
            border-radius: 4px;
            padding: 6px 10px;
            font-size: 12px;
            resize: none;
            min-height: 38px;
            font-family: 'IBM Plex Sans', sans-serif;
        }

    .btn-approve {
        background: #1a5c3a;
        color: #fff;
    }

    .btn-reject {
        background: #8a1a1a;
        color: #fff;
    }

    .btn-approve:hover {
        background: #14472d;
    }

    .btn-reject:hover {
        background: #6e1414;
    }

    .no-emp-selected {
        text-align: center;
        padding: 40px;
        color: #7a94aa;
        font-size: 13px;
        background: #f8fafc;
        border: 1px dashed #c8d8e8;
        border-radius: 8px;
    }
</style>

<!-- Breadcrumb -->
<div class="row">
    <div class="col-sm-12">
        <div class="page-title-box">
            <div class="float-end">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">DRCTS</a></li>
                    <li class="breadcrumb-item"><a href="#">Attendance</a></li>
                    <li class="breadcrumb-item active">Project Timesheet</li>
                </ol>
            </div>
            <h4 class="page-title">Project Timesheet</h4>
        </div>
    </div>
</div>

<div class="card assign-card">
    <div class="card-body" style="padding-top: 0;">

        <!-- ── Tab Strip ── -->
        <div class="ts-tab-strip">
            <button class="ts-tab-btn active" onclick="switchTab('employee', this)">📋 Timesheet</button>
            <button class="ts-tab-btn" id="approvalTabContainer" onclick="switchTab('manager',  this)">👥 Team Timesheets</button>
        </div>

        <!-- ══════════════════════════════════════════════════
             EMPLOYEE TAB
        ══════════════════════════════════════════════════ -->
        <div class="ts-tab-pane active" id="tab-employee" style="padding-top: 16px;">

            <!-- Week Navigator -->
            <div class="week-nav">
                <label>Current Week</label>
                <button class="nav-btn" onclick="emp.changeWeek(-1)">&#171;</button>
                <div>
                    <div class="week-label" id="emp-weekRange">--</div>
                    <div class="week-sub" id="emp-weekSub">--</div>
                </div>
                <button class="nav-btn" onclick="emp.changeWeek(1)">&#187;</button>
                <select class="year-select" id="emp-yearSelect" onchange="emp.onYearChange(this.value)">
                    <option value="2025">2025</option>
                    <option value="2026" selected>2026</option>
                    <option value="2027">2027</option>
                </select>
                <button class="refresh-btn" onclick="emp.refresh()">
                    <span class="spin" id="emp-spinIcon">&#8635;</span> Refresh
                </button>
            </div>

            <!-- Status Bar -->
            <div class="status-bar">
                <span class="emp-info">Employee &nbsp;<span id="emp-empInfo">--</span></span>
                <span class="emp-info">Approver – <span id="emp-approverInfo">--</span></span>
                <span class="status-badge" id="emp-statusBadge">--</span>
                <span class="view-history" onclick="emp.viewHistory()">View History</span>
            </div>

            <!-- Employee Dark Row -->
            <div class="emp-row">
                <span class="emp-field">Employee</span>
                <span class="emp-val" id="emp-empNameFull">--</span>
                <span style="margin-left:20px;" class="emp-field">Approver</span>
                <span class="emp-val" id="emp-approverFull">--</span>
            </div>

            <!-- Legend -->
            <div class="legend">
                <strong style="font-size:11px;color:#4a6080;margin-right:4px;">Legend:</strong>
                <div class="legend-item"><div class="legend-dot present"></div>Present</div>
                <div class="legend-item"><div class="legend-dot absent"></div>Absent</div>
                <div class="legend-item"><div class="legend-dot holiday"></div>Public Holiday</div>
                <div class="legend-item"><div class="legend-dot weekend"></div>Weekend</div>
                <div class="legend-item"><div class="legend-dot today"></div>Today</div>
            </div>

            <div id="emp-loadingMsg" style="text-align:center;padding:30px;color:#2e5f8a;font-size:14px;">⏳ Loading timesheet...</div>
            <div id="emp-noDataMsg" style="display:none;text-align:center;padding:30px;color:#888;font-size:14px;">❌ No timesheet data available for this week.</div>

            <div class="table-wrap" id="emp-tableSection" style="display:none;">
                <table id="emp-timesheetTable">
                    <thead>
                        <tr id="emp-dateRow">
                            <th rowspan="2" style="min-width:220px;">Project / Activity / Category / Shift</th>
                            <th rowspan="2" style="min-width:150px;">Remarks</th>
                            <th rowspan="2" class="action-cell-header">Action</th>
                        </tr>
                        <tr class="day-row" id="emp-dayRow"></tr>
                    </thead>
                    <tbody id="emp-timesheetBody"></tbody>
                </table>
                <div class="actions-bar">
                    <button class="btn btn-add" onclick="emp.addRow()">&#43; Add Row</button>
                    <button class="btn btn-upload" onclick="emp.uploadAttachment()">Upload</button>
                    <button class="btn btn-save" onclick="emp.saveSheet()">Save</button>
                    <button class="btn btn-submit" onclick="emp.submitSheet()">Submit</button>
                </div>
                <div class="summary-bar" id="emp-summaryBar"></div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════
             MANAGER TAB
        ══════════════════════════════════════════════════ -->
        <div class="ts-tab-pane" id="tab-manager" style="padding-top: 16px;">

            <!-- Toolbar -->
            <div class="mgr-toolbar">
                <label>Week</label>
                <button class="nav-btn" onclick="mgr.changeWeek(-1)">&#171;</button>
                <div>
                    <div class="week-label" id="mgr-weekRange">--</div>
                </div>
                <button class="nav-btn" onclick="mgr.changeWeek(1)">&#187;</button>
                <select class="year-select" id="mgr-yearSelect" onchange="mgr.onYearChange(this.value)">
                    <option value="2025">2025</option>
                    <option value="2026" selected>2026</option>
                    <option value="2027">2027</option>
                </select>
                <button class="refresh-btn" onclick="mgr.refresh()">
                    <span class="spin" id="mgr-spinIcon">&#8635;</span> Refresh
                </button>
                <div class="mgr-filter-btns">
                    <button class="filter-btn active" onclick="mgr.setFilter('ALL',   this)">All</button>
                    <button class="filter-btn" onclick="mgr.setFilter('PENDING',  this)">Pending</button>
                    <button class="filter-btn" onclick="mgr.setFilter('APPROVED', this)">Approved</button>
                    <button class="filter-btn" onclick="mgr.setFilter('REJECTED', this)">Rejected</button>
                    <button class="filter-btn" onclick="mgr.setFilter('DRAFT',    this)">Draft</button>
                </div>
            </div>

            <!-- Loading / No Data for manager -->
            <div id="mgr-loadingMsg" style="text-align:center;padding:30px;color:#2e5f8a;font-size:14px;">⏳ Loading team timesheets...</div>
            <div id="mgr-noDataMsg" style="display:none;text-align:center;padding:30px;color:#888;font-size:14px;">❌ No team timesheet data for this week.</div>

            <div id="mgr-mainSection" style="display:none;">
                <!-- Employee cards grid -->
                <div class="emp-cards" id="mgr-empCards"></div>

                <!-- Detail panel -->
                <div id="mgr-detailPanel">
                    <div class="no-emp-selected" id="mgr-noEmpMsg">
                        👆 Select an employee above to review their timesheet
                    </div>
                    <div id="mgr-timesheetDetail" style="display:none;">
                        <div class="mgr-detail-header">
                            <div>
                                <div class="emp-name" id="mgr-detailEmpName">--</div>
                                <div style="font-size:11px;color:#8ab0cc;" id="mgr-detailEmpCode">--</div>
                            </div>
                            <span class="status-pill" id="mgr-detailStatus" style="margin-left:12px;">--</span>
                            <span class="week-lbl" id="mgr-detailWeekLbl">--</span>
                        </div>
                        <div class="table-wrap">
                            <table id="mgr-timesheetTable">
                                <thead>
                                    <tr id="mgr-dateRow">
                                        <th rowspan="2" style="min-width:220px;">Project / Activity / Category / Shift</th>
                                        <th rowspan="2" style="min-width:150px;">Remarks</th>
                                    </tr>
                                    <tr id="mgr-dayRow"></tr>
                                </thead>
                                <tbody id="mgr-timesheetBody"></tbody>
                            </table>
                        </div>
                        <div class="summary-bar" id="mgr-summaryBar"></div>

                        <!-- Approve / Reject bar -->
                        <div class="approve-bar" id="mgr-approveBar">
                            <textarea id="mgr-approveRemarks" placeholder="Remarks (optional for Approve, required for Reject)..." rows="1"></textarea>
                            <button class="btn btn-approve" onclick="mgr.approveReject('APPROVED')">✔ Approve</button>
                            <button class="btn btn-reject" onclick="mgr.approveReject('REJECTED')">✘ Reject</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /card-body -->
</div>

<!-- Toast -->
<div class="ts-toast" id="tsToast"></div>

<!-- History Modal (shared) -->
<div class="modal fade" id="historyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background:#1a3a5c;color:#fff;">
                <h5 class="modal-title">📋 Timesheet History</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="historyBody">
                <p class="text-center text-muted">Loading...</p>
            </div>
        </div>
    </div>
</div>

