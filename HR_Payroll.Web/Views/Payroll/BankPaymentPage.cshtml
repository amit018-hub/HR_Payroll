
@{
    ViewData["Title"] = "BankPaymentPage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h4>Bank Salary Payment</h4>

<div class="card">
    <div class="card-body">
        <p><strong>Payroll Month:</strong> Jan 2025</p>
        <p><strong>Total Employees:</strong> 25</p>
        <p><strong>Total Amount:</strong> ₹12,50,000</p>

        <button class="btn btn-primary">
            Generate Bank Sheet
        </button>

        <button class="btn btn-success">
            Mark Payment Done
        </button>
    </div>
</div>

<table class="table mt-4">
    <thead>
        <tr>
            <th>Emp Code</th>
            <th>Name</th>
            <th>Bank</th>
            <th>Account</th>
            <th>Net Pay</th>
            <th>Status</th>
        </tr>
    </thead>
</table>


