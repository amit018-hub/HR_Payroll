@model HR_Payroll.Core.DTO.Payroll.SalarySlipDto
@{
    ViewData["Title"] = "Salary Slip";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var monthName = Model != null ? new System.DateTime(Model.PayrollYear, Model.PayrollMonth, 1).ToString("MMMM yyyy") : "-";
    var statusLabel = Model?.Status switch { "Paid" => "PAID", "Approved" => "APPROVED", "Draft" => "DRAFT", _ => "PENDING" };
    var sealColor = Model?.Status switch { "Paid" => "#3CB371", "Approved" => "#4A90A4", "Draft" => "#B8922A", _ => "#9CA3AF" };
    var earnings = Model?.Earnings.Where(l => l.Amount != 0).ToList() ?? new();
    var deductions = Model?.Deductions.Where(l => l.Amount != 0).ToList() ?? new();
    bool hasDed = deductions.Any();
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
    .ps-page {
        background: #ECEEF1;
        padding: 20px 12px 40px
    }

    .ps-actions {
        max-width: 800px;
        margin: 0 auto 12px;
        display: flex;
        justify-content: flex-end;
        gap: 8px
    }

        .ps-actions button {
            font-family: "Inter",sans-serif;
            font-size: 13px;
            font-weight: 500;
            padding: 8px 20px;
            border-radius: 6px;
            cursor: pointer;
            transition: all .15s
        }

    .ps-btn-o {
        border: 1.5px solid #0D1B2A;
        background: transparent;
        color: #0D1B2A
    }

        .ps-btn-o:hover {
            background: #0D1B2A;
            color: #fff
        }

    .ps-btn-s {
        border: 1.5px solid #0D1B2A;
        background: #0D1B2A;
        color: #fff
    }

        .ps-btn-s:hover {
            opacity: .85
        }

    .ps-card {
        max-width: 800px;
        margin: 0 auto;
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 8px 40px rgba(0,0,0,.13)
    }

    .ps-hero {
        background: #0D1B2A;
        padding: 28px 36px 24px;
        position: relative;
        overflow: hidden
    }

    .ps-hero-glow {
        position: absolute;
        inset: 0;
        opacity: .07;
        background: radial-gradient(circle at 20% 50%,#B8922A,transparent 55%),radial-gradient(circle at 85% 20%,#4A90A4,transparent 45%)
    }

    .ps-hero-inner {
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: flex-start
    }

    .ps-co {
        display: flex;
        align-items: center;
        gap: 14px
    }

    .ps-mono {
        width: 50px;
        height: 50px;
        background: #B8922A;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Playfair Display",serif;
        font-size: 28px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0
    }

    .ps-coname {
        font-family: "Playfair Display",serif;
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        line-height: 1.25
    }

    .ps-cosub {
        font-size: 11px;
        color: rgba(255,255,255,.45);
        margin-top: 3px
    }

    .ps-right {
        text-align: right
    }

    .ps-tag {
        font-family: "JetBrains Mono",monospace;
        font-size: 10px;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: rgba(255,255,255,.4)
    }

    .ps-month {
        font-family: "Playfair Display",serif;
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-top: 2px
    }

    .ps-seal {
        display: inline-block;
        margin-top: 8px;
        border: 1.5px solid;
        border-radius: 4px;
        font-family: "JetBrains Mono",monospace;
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 2.5px;
        padding: 3px 10px;
        transform: rotate(5deg);
        text-transform: uppercase
    }

    .ps-gold {
        height: 3px;
        background: linear-gradient(90deg,#B8922A 0%,#E6C96A 50%,#B8922A 100%)
    }

    .ps-emp {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        border-bottom: 1px solid #E8EBF0
    }

    .ps-emp2 {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        border-bottom: 2px solid #0D1B2A
    }

        .ps-emp2 .ps-cell {
            background: #F8F9FB
        }

    .ps-cell {
        padding: 14px 20px;
        border-right: 1px solid #E8EBF0
    }

        .ps-cell:last-child {
            border-right: none
        }

    .ps-lbl {
        font-family: "JetBrains Mono",monospace;
        font-size: 10px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #9CA3AF;
        margin-bottom: 4px
    }

    .ps-val {
        font-size: 13.5px;
        font-weight: 600;
        color: #111827
    }

        .ps-val.mono {
            font-family: "JetBrains Mono",monospace;
            font-size: 12.5px
        }

    .ps-pending {
        margin: 16px 24px;
        padding: 12px 16px;
        border-left: 3px solid #B8922A;
        background: #FEFBF3;
        font-size: 13px;
        color: #6B7280;
        border-radius: 0 4px 4px 0
    }

    .ps-ledger {
        display: grid;
        grid-template-columns: @(hasDed ? "1fr 1fr" : "1fr")
    }

    .ps-lcol {
        padding: 20px 24px
    }

        .ps-lcol:first-child {
            border-right: @(hasDed ? "1px solid #E8EBF0" : "none")
        }

    .ps-lhead {
        font-family: "JetBrains Mono",monospace;
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #6B7280;
        padding-bottom: 10px;
        border-bottom: 1.5px solid #111827;
        margin-bottom: 4px
    }

    .ps-lrow {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #F1F3F7;
        font-size: 13px;
        color: #374151
    }

        .ps-lrow.ear .amt {
            color: #1A4731;
            font-weight: 600
        }

        .ps-lrow.ded .amt {
            color: #991B1B;
            font-weight: 600
        }

        .ps-lrow .amt {
            font-family: "JetBrains Mono",monospace;
            font-size: 13px
        }

    .ps-ltot {
        display: flex;
        justify-content: space-between;
        padding: 10px 0 4px;
        border-top: 1.5px solid #111827;
        margin-top: 4px;
        font-weight: 700;
        font-size: 13.5px;
        color: #111827
    }

        .ps-ltot .amt {
            font-family: "JetBrains Mono",monospace;
            font-weight: 700
        }

    .ps-net {
        background: #1A4731;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 22px 30px;
        position: relative;
        overflow: hidden
    }

        .ps-net::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient(-48deg,transparent,transparent 9px,rgba(255,255,255,.03) 9px,rgba(255,255,255,.03) 10px)
        }

    .ps-net-l {
        position: relative
    }

    .ps-net-lbl {
        font-family: "JetBrains Mono",monospace;
        font-size: 10px;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: rgba(255,255,255,.55)
    }

    .ps-net-words {
        font-size: 11.5px;
        color: rgba(255,255,255,.5);
        font-style: italic;
        margin-top: 4px;
        max-width: 380px
    }

    .ps-net-amt {
        font-family: "JetBrains Mono",monospace;
        font-size: 34px;
        font-weight: 600;
        color: #fff;
        letter-spacing: -1px;
        position: relative
    }

    .ps-net-cur {
        font-size: 20px;
        font-weight: 500;
        vertical-align: super;
        margin-right: 2px
    }

    .ps-foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 28px 16px;
        background: #F8F9FB;
        border-top: 1px solid #E8EBF0
    }

    .ps-foot-sig {
        font-size: 11px;
        color: #9CA3AF
    }

        .ps-foot-sig strong {
            color: #6B7280;
            font-weight: 600
        }

    .ps-foot-stamp {
        font-family: "JetBrains Mono",monospace;
        font-size: 10px;
        letter-spacing: 1.5px;
        color: #B8922A;
        text-transform: uppercase
    }

    @@media print {
        .ps-page {
            background: #fff;
            padding: 0
        }

        .ps-actions {
            display: none
        }

        .ps-card {
            box-shadow: none;
            border-radius: 0
        }
    }
</style>

<div class="row">
    <div class="col-sm-12">
        <div class="page-title-box">
            <div class="float-end">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">DRCTS</a></li>
                    <li class="breadcrumb-item"><a href="#">Payroll</a></li>
                    <li class="breadcrumb-item active">Pay Slip</li>
                </ol>
            </div>
            <h4 class="page-title">Salary Slip</h4>
        </div>
    </div>
</div>

<div class="ps-page">
    @if (Model == null)
    {
        <div class="alert alert-warning" style="max-width:800px;margin:0 auto">
            @(ViewBag.LoadError as string ?? "No salary slip data available for this employee / month.")
        </div>
    }
    else
    {
        <div class="ps-actions">
            <button class="ps-btn-o" onclick="window.print()">&#128424; Print</button>
            <button class="ps-btn-s" onclick="downloadPayslip()">&#8659; Download PDF</button>
        </div>

        <div class="ps-card" id="payslip-root">

            <!-- Dark hero -->
            <div class="ps-hero">
                <div class="ps-hero-glow"></div>
                <div class="ps-hero-inner">
                    <div class="ps-co">
                        <div class="ps-mono">D</div>
                        <div>
                            <div class="ps-coname">DRCTS Technologies Pvt. Ltd.</div>
                            <div class="ps-cosub">Bengaluru, India &nbsp;·&nbsp; CIN: U72200KA2020PTC123456</div>
                        </div>
                    </div>
                    <div class="ps-right">
                        <div class="ps-tag">Pay Slip</div>
                        <div class="ps-month">@monthName</div>
                        <span class="ps-seal" style="color:@sealColor;border-color:@sealColor">@statusLabel</span>
                    </div>
                </div>
            </div>
            <div class="ps-gold"></div>

            <!-- Employee — row 1 -->
            <div class="ps-emp">
                <div class="ps-cell">
                    <div class="ps-lbl">Employee Name</div>
                    <div class="ps-val">@Model.EmployeeName</div>
                </div>
                <div class="ps-cell">
                    <div class="ps-lbl">Employee ID</div>
                    <div class="ps-val mono">@Model.EmployeeCode</div>
                </div>
                <div class="ps-cell">
                    <div class="ps-lbl">Designation</div>
                    <div class="ps-val">@(string.IsNullOrWhiteSpace(Model.Designation) || Model.Designation == "-" ? "—" : Model.Designation)</div>
                </div>
            </div>

            <!-- Employee — row 2 -->
            <div class="ps-emp2">
                <div class="ps-cell">
                    <div class="ps-lbl">Department</div>
                    <div class="ps-val">@(Model.DepartmentName ?? "—")</div>
                </div>
                <div class="ps-cell">
                    <div class="ps-lbl">Date of Joining</div>
                    <div class="ps-val">@(Model.JoiningDate?.ToString("dd MMM yyyy") ?? "—")</div>
                </div>
                <div class="ps-cell">
                    <div class="ps-lbl">Bank Account</div>
                    <div class="ps-val mono">@(Model.MaskedBankAccount ?? "Not on file")</div>
                </div>
            </div>

            @if (Model.Status == "Not Calculated" || Model.Status == "Pending")
            {
                <div class="ps-pending">
                    Payroll not yet calculated for this period. Run <strong>Calculate Payroll</strong> on the Payroll Processing page to populate figures.
                </div>
            }

            <!-- Ledger -->
            <div class="ps-ledger">
                <!-- Earnings -->
                <div class="ps-lcol">
                    <div class="ps-lhead">Earnings</div>
                    @if (!earnings.Any())
                    {
                        <div class="ps-lrow" style="color:#9CA3AF;font-size:13px">No earnings components configured</div>
                    }
                    @foreach (var line in earnings)
                    {
                        <div class="ps-lrow ear">
                            <span>@line.ComponentName</span>
                            <span class="amt">&#8377;@line.Amount.ToString("N0")</span>
                        </div>
                    }
                    <div class="ps-ltot">
                        <span>Total earnings</span>
                        <span class="amt">&#8377;@Model.TotalEarnings.ToString("N0")</span>
                    </div>
                </div>

                @if (hasDed)
                {
                    <!-- Deductions -->
                    <div class="ps-lcol">
                        <div class="ps-lhead">Deductions</div>
                        @foreach (var line in deductions)
                        {
                            <div class="ps-lrow ded">
                                <span>@line.ComponentName</span>
                                <span class="amt">&#8377;@line.Amount.ToString("N0")</span>
                            </div>
                        }
                        <div class="ps-ltot">
                            <span>Total deductions</span>
                            <span class="amt">&#8377;@Model.TotalDeductions.ToString("N0")</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Net pay -->
            <div class="ps-net">
                <div class="ps-net-l">
                    <div class="ps-net-lbl">Net Salary Payable</div>
                    <div class="ps-net-words">@Model.NetSalaryInWords</div>
                </div>
                <div class="ps-net-amt">
                    <span class="ps-net-cur">&#8377;</span>@Model.NetSalary.ToString("N0")
                </div>
            </div>

            <!-- Footer -->
            <div class="ps-foot">
                <div class="ps-foot-sig">
                    Authorised signatory &nbsp;·&nbsp; <strong>DRCTS Technologies Pvt. Ltd.</strong>
                </div>
                <div class="ps-foot-stamp">System Generated · No Signature Required</div>
            </div>

        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
        <script>
            function downloadPayslip() {
                html2pdf().set({
                    margin: 6,
                    filename: 'Payslip_@(Model.EmployeeCode)_@(monthName.Replace(" ", "_")).pdf',
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2, useCORS: true },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
                }).from(document.getElementById('payslip-root')).save();
            }
        </script>
    }
</div>
