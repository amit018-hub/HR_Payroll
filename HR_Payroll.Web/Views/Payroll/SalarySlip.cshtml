@model HR_Payroll.Core.DTO.Payroll.SalarySlipDto
@{
    ViewData["Title"] = "Salary slip";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var monthName = Model != null ? new System.DateTime(Model.PayrollYear, Model.PayrollMonth, 1).ToString("MMMM yyyy") : "-";
    var statusLabel = Model?.Status switch
    {
        "Paid" => "PAID",
        "Approved" => "APPROVED",
        "Draft" => "DRAFT",
        _ => "NOT CALCULATED"
    };
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,500;8..60,600&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
    .payslip-page {
        --ink: #1B1F23;
        --paper: #F7F5F1;
        --card: #FFFFFF;
        --brass: #8A7B5C;
        --ledger-green: #1E5631;
        --rule: #C7C1B4;
        --muted: #6B675F;
        background: var(--paper);
        padding: 32px 16px;
        border-radius: 10px;
    }

    .payslip-container {
        position: relative;
        max-width: 880px;
        margin: auto;
        background: var(--card);
        border: 1px solid var(--rule);
        padding: 0;
        overflow: hidden;
        color: var(--ink);
        font-family: "Inter", sans-serif;
    }

    .payslip-band {
        height: 6px;
        background: var(--ink);
    }

    .payslip-inner {
        padding: 36px 44px 30px;
    }

    /* Status seal — the signature element. Rotated like a real stamp, color and
           label driven entirely by the actual payroll Status, not decorative. */
    .payslip-seal {
        position: absolute;
        top: 38px;
        right: 44px;
        border: 2.5px solid var(--brass);
        color: var(--brass);
        font-family: "IBM Plex Mono", monospace;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 2px;
        padding: 6px 14px;
        border-radius: 4px;
        transform: rotate(8deg);
        opacity: 0.85;
    }

        .payslip-seal.is-paid {
            border-color: var(--ledger-green);
            color: var(--ledger-green);
        }

        .payslip-seal.is-pending {
            border-color: var(--muted);
            color: var(--muted);
        }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: 18px;
        border-bottom: 2px solid var(--ink);
    }

    .company-details h2 {
        margin: 0;
        font-family: "Source Serif 4", Georgia, serif;
        font-size: 24px;
        font-weight: 600;
        letter-spacing: 0.2px;
    }

    .company-details p {
        margin: 4px 0 0;
        font-size: 12px;
        color: var(--muted);
    }

    .payslip-title {
        text-align: right;
    }

        .payslip-title .eyebrow {
            font-family: "IBM Plex Mono", monospace;
            font-size: 11px;
            letter-spacing: 2px;
            color: var(--muted);
            text-transform: uppercase;
        }

        .payslip-title .period {
            margin-top: 2px;
            font-family: "Source Serif 4", Georgia, serif;
            font-size: 19px;
            font-weight: 600;
        }

    /* Employee facts — quiet two-column label/value list, not a boxed table */
    .fact-grid {
        margin-top: 24px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 32px;
        border-top: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
        padding: 16px 0;
    }

    .fact-row {
        display: flex;
        justify-content: space-between;
        padding: 5px 0;
        font-size: 13px;
    }

        .fact-row dt {
            color: var(--muted);
        }

        .fact-row dd {
            margin: 0;
            font-weight: 500;
            text-align: right;
        }

    .pending-note {
        margin-top: 18px;
        padding: 12px 16px;
        border: 1px dashed var(--rule);
        border-radius: 4px;
        font-size: 13px;
        color: var(--muted);
        background: #FBFAF8;
    }

    /* Earnings / deductions — ledger columns, mono figures, no card chrome */
    .ledger-section {
        margin-top: 28px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 36px;
    }

    .ledger-col h4 {
        margin: 0 0 10px;
        font-family: "IBM Plex Mono", monospace;
        font-size: 11px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--muted);
        padding-bottom: 8px;
        border-bottom: 1px solid var(--ink);
    }

    .ledger-row {
        display: flex;
        justify-content: space-between;
        padding: 7px 0;
        font-size: 13.5px;
        border-bottom: 1px solid var(--rule);
    }

        .ledger-row .amount {
            font-family: "IBM Plex Mono", monospace;
            font-variant-numeric: tabular-nums;
            font-weight: 500;
        }

        .ledger-row.total {
            border-bottom: none;
            border-top: 1.5px solid var(--ink);
            margin-top: 4px;
            padding-top: 9px;
            font-weight: 600;
        }

    /* Net pay — the one place color is spent */
    .net-salary {
        margin-top: 26px;
        background: var(--ledger-green);
        color: #fff;
        padding: 18px 24px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        border-radius: 4px;
    }

        .net-salary .label {
            font-family: "IBM Plex Mono", monospace;
            font-size: 12px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            opacity: 0.85;
        }

        .net-salary .amount {
            font-family: "IBM Plex Mono", monospace;
            font-size: 24px;
            font-weight: 600;
            font-variant-numeric: tabular-nums;
        }

    .footer {
        margin-top: 22px;
        padding-top: 16px;
        border-top: 1px solid var(--rule);
        font-size: 12px;
        color: var(--muted);
    }

        .footer .in-words {
            color: var(--ink);
            font-style: italic;
        }

        .footer p {
            margin: 4px 0;
        }

    @@media print {
        .payslip-page {
            background: #fff;
            padding: 0;
        }

        .payslip-container {
            border: none;
        }

        .action-bar {
            display: none;
        }
    }

    .action-bar {
        max-width: 880px;
        margin: 0 auto 14px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

        .action-bar button {
            border: 1px solid var(--ink, #1B1F23);
            background: transparent;
            color: var(--ink, #1B1F23);
            padding: 8px 18px;
            border-radius: 4px;
            font-family: "Inter", sans-serif;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
        }

            .action-bar button:hover {
                background: var(--ink, #1B1F23);
                color: #fff;
            }

            .action-bar button.primary {
                background: var(--ink, #1B1F23);
                color: #fff;
            }

                .action-bar button.primary:hover {
                    opacity: 0.85;
                }
</style>
<div class="row">
    <div class="col-sm-12">
        <div class="page-title-box">
            <div class="float-end">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">DRCTS</a></li>
                    <li class="breadcrumb-item"><a href="#">Payroll</a></li>
                    <li class="breadcrumb-item active">Pay slip</li>
                </ol>
            </div>
            <h4 class="page-title">Salary slip</h4>
        </div>
        <!--end page-title-box-->
    </div>
    <!--end col-->
</div>

<div class="payslip-page">
    @if (Model == null)
    {
        <div class="alert alert-warning mb-0">
            @(ViewBag.LoadError as string ?? "No salary slip data is available for this employee/month.")
        </div>
    }
    else
    {
        <div class="action-bar">
            <button onclick="window.print()">Print</button>
            <button class="primary" onclick="downloadPayslip()">Download PDF</button>
        </div>

        <div class="payslip-container">
            <div class="payslip-band"></div>
            <div class="payslip-inner">

                <div class="payslip-seal @(Model.Status == "Paid" ? "is-paid" : Model.Status == "Not Calculated" ? "is-pending" : "")">
                    @statusLabel
                </div>

                <!-- Header -->
                <div class="header">
                    <div class="company-details">
                        <h2>DRCTS Technologies Pvt. Ltd.</h2>
                        <p>Bengaluru, India</p>
                    </div>
                    <div class="payslip-title">
                        <div class="eyebrow">Pay slip</div>
                        <div class="period">@monthName</div>
                    </div>
                </div>

                <!-- Employee Details -->
                <dl class="fact-grid">
                    <div class="fact-row">
                        <dt>Employee name</dt>
                        <dd>@Model.EmployeeName</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Employee ID</dt>
                        <dd>@Model.EmployeeCode</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Designation</dt>
                        <dd>@(Model.Designation ?? "-")</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Department</dt>
                        <dd>@(Model.DepartmentName ?? "-")</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Date of joining</dt>
                        <dd>@(Model.JoiningDate?.ToString("dd MMM yyyy") ?? "-")</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Bank account</dt>
                        <dd>@(Model.MaskedBankAccount ?? "Not on file")</dd>
                    </div>
                </dl>

                @if (Model.Status == "Not Calculated")
                {
                    <div class="pending-note">
                        Payroll has not been calculated yet for this employee and month. Figures below are zero until "Calculate Payroll" is run on the Payroll Processing page.
                    </div>
                }

                <!-- Salary Details -->
                <div class="ledger-section">
                    <!-- Earnings -->
                    <div class="ledger-col">
                        <h4>Earnings</h4>
                        @foreach (var line in Model.Earnings)
                        {
                            <div class="ledger-row">
                                <span>@line.ComponentName</span>
                                <span class="amount">₹@line.Amount.ToString("N0")</span>
                            </div>
                        }
                        <div class="ledger-row total">
                            <span>Total earnings</span>
                            <span class="amount">₹@Model.TotalEarnings.ToString("N0")</span>
                        </div>
                    </div>

                    <!-- Deductions -->
                    <div class="ledger-col">
                        <h4>Deductions</h4>
                        @foreach (var line in Model.Deductions)
                        {
                            <div class="ledger-row">
                                <span>@line.ComponentName</span>
                                <span class="amount">₹@line.Amount.ToString("N0")</span>
                            </div>
                        }
                        <div class="ledger-row total">
                            <span>Total deductions</span>
                            <span class="amount">₹@Model.TotalDeductions.ToString("N0")</span>
                        </div>
                    </div>
                </div>

                <!-- Net Salary -->
                <div class="net-salary">
                    <span class="label">Net salary payable</span>
                    <span class="amount">₹@Model.NetSalary.ToString("N0")</span>
                </div>

                <!-- Footer -->
                <div class="footer">
                    <p>Amount in words: <span class="in-words">@Model.NetSalaryInWords</span></p>
                    <p>This is a system-generated payslip and does not require a signature.</p>
                </div>

            </div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
        <script>
            function downloadPayslip() {
                const element = document.querySelector('.payslip-container');
                const opt = {
                    margin: 0,
                    filename: 'Payslip.pdf',
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2 },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };

                if (window.html2pdf) {
                    html2pdf().set(opt).from(element).save();
                } else {
                    alert('html2pdf library not loaded');
                }
            }
        </script>
    }
</div>
